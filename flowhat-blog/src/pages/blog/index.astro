---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = allPosts.filter((post) => (post.data.lang ?? 'en') === 'en');
const languageOrder = ['en', 'zh', 'ko'];
const languageLabels = { en: 'EN', zh: 'ZH', ko: 'KO' };
const translationMap = new Map();
for (const post of allPosts) {
	const key = post.data.translationGroup ?? post.data.baseSlug ?? post.id;
	const existing = translationMap.get(key) ?? [];
	existing.push(post);
	translationMap.set(key, existing);
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.language-badges {
				display: flex;
				gap: 0.35rem;
				margin: 0.45rem 0 0.2rem 0;
				flex-wrap: wrap;
			}
			.language-badges span {
				font-size: 0.78rem;
				padding: 0.18rem 0.45rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				color: rgb(var(--gray-dark));
				background: white;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						posts.map((post) => {
						const lang = post.data.lang ?? 'en';
						const baseSlug = post.data.baseSlug ?? post.id;
						const href = lang === 'en' ? `/blog/${baseSlug}/` : `/blog/${baseSlug}/${lang}/`;
						return (
							<li>
								<a href={href}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<div class="language-badges">
										{languageOrder
											.filter((lang) => (translationMap.get(post.data.translationGroup ?? post.data.baseSlug ?? post.id) ?? []).some((item) => (item.data.lang ?? 'en') === lang))
											.map((lang) => <span>{languageLabels[lang]}</span>)}
									</div>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						);
					})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
