---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Page Not Found" description="The requested FlowHat Blog page could not be found">
	<h1>Page Not Found</h1>
	<p>
		The page you requested does not exist, may have moved, or may have been mistyped.
	</p>
	<p>
		You can return to the <a href="/">home page</a>, browse the <a href="/blog/">blog archive</a>, or
		use the <a href="/contact/">contact page</a> to report a broken link.
	</p>
</PageLayout>
