---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Practical writing on LLMs and agents.</h1>
			<p>
				FlowHat Blog covers models, agent tools, coding workflows, and the boring practical details that
				actually matter when you try to use them in real work.
			</p>
			<p>
				This is not a summary farm. Posts here are meant to add synthesis, comparisons, tradeoffs, and
				usable guidance.
			</p>
			<p>
				Start with the <a href="/blog/">blog archive</a>. More posts will be published through a simple
				git-based workflow.
			</p>
		</main>
		<Footer />
	</body>
</html>
