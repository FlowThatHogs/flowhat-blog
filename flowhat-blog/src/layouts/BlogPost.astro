---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	languageLinks?: { lang: string; href: string; label: string }[];
};

const { title, description, pubDate, updatedDate, heroImage, languageLinks = [] } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: min(820px, calc(100% - 2em));
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.monetization-box {
				margin-top: 2.5rem;
				padding-top: 0.9rem;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.monetization-box h3 {
				margin: 0 0 0.45rem 0;
				font-size: 0.92rem;
				font-weight: 600;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 0.04em;
			}
			.monetization-box p {
				margin: 0.25rem 0;
				font-size: 0.92rem;
				color: rgb(var(--gray-dark));
			}
			.monetization-links {
				display: flex;
				gap: 0.85rem;
				flex-wrap: wrap;
				margin-top: 0.45rem;
			}
			.monetization-links a {
				color: rgb(var(--gray-dark));
				text-decoration: none;
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 0.08rem;
			}
			.monetization-links a:hover {
				color: rgb(var(--accent));
				border-bottom-color: rgb(var(--accent));
			}
			.monetization-note {
				margin-top: 0.55rem;
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
			@media (min-width: 1100px) {
				.prose {
					width: min(900px, calc(100% - 4em));
				}
			}
			@media (max-width: 720px) {
				.language-switcher {
					position: static;
					justify-content: center;
					margin-bottom: 0.75rem;
				}
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
				position: relative;
			}
			.language-switcher {
				position: absolute;
				top: -0.15rem;
				right: -1.8rem;
				display: flex;
				gap: 0.5rem;
				font-size: 1.12rem;
			}
			.language-switcher a,
			.language-switcher span {
				padding: 0.32rem 0.72rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				background: white;
			}
			.language-switcher span {
				font-weight: 700;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						{languageLinks.length > 0 && (
							<div class="language-switcher">
								{languageLinks.map((item) =>
									item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>
								)}
							</div>
						)}
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
					<div class="monetization-box">
						<h3>Related links</h3>
						<p>General marketplace links for future gear and tool references.</p>
						<div class="monetization-links">
							<a href="https://www.coupang.com/" rel="nofollow noopener noreferrer">Coupang</a>
							<a href="https://www.amazon.com/" rel="nofollow noopener noreferrer">Amazon</a>
							<a href="https://www.aliexpress.com/" rel="nofollow noopener noreferrer">AliExpress</a>
						</div>
						<p class="monetization-note">Some outbound links may later become affiliate links. See the disclosure page for details.</p>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
