---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	languageLinks?: { lang: string; href: string; label: string }[];
	alternateLinks?: { lang: string; href: string }[];
};

const { title, description, pubDate, updatedDate, heroImage, lang = 'en', languageLinks = [], alternateLinks = [] } = Astro.props;
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} alternateLinks={alternateLinks} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: min(820px, calc(100% - 2em));
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			@media (min-width: 1100px) {
				.prose {
					width: min(900px, calc(100% - 4em));
				}
			}
			@media (max-width: 720px) {
				.language-switcher {
					position: static;
					justify-content: center;
					margin-bottom: 0.75rem;
				}
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
				position: relative;
			}
			.language-switcher {
				position: absolute;
				top: -0.15rem;
				right: -1.8rem;
				display: flex;
				gap: 0.5rem;
				font-size: 1.12rem;
			}
			.language-switcher a,
			.language-switcher span {
				padding: 0.32rem 0.72rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				background: white;
			}
			.language-switcher span {
				font-weight: 700;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						{languageLinks.length > 0 && (
							<div class="language-switcher">
								{languageLinks.map((item) =>
									item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>
								)}
							</div>
						)}
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
